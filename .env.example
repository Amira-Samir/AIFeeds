# Copy to .env.local and fill in (".env.local" is gitignored — never commit real keys).
#
# Anthropic API key used for in-browser article summarization.
# Optional: without it the app still works, showing RSS excerpts instead of AI summaries.
# NOTE: a browser-exposed key is for local dev/demo only — production needs a server proxy.
VITE_ANTHROPIC_API_KEY=
